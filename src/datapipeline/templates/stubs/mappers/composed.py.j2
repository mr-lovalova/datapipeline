from typing import Iterator, Mapping

from datapipeline.composed import align_many
from datapipeline.domain.record import TemporalRecord


def mapper(
    inputs: Mapping[str, Iterator[TemporalRecord]],
    *,
    context,
    driver: str | None = None,
    join: str = "inner",
    partition_by: str | list[str] | None = None,
    **params,
) -> Iterator[TemporalRecord]:
    # TODO: implement domain math over aligned rows (timestamp + alias->record).
    del context
    del params
    for row in align_many(
        inputs,
        driver=driver,
        join=join,
        partition_by=partition_by,
    ):
        key = driver or next(iter(row.values.keys()))
        rec = row.values.get(key)
        if rec is None:
            continue
        yield rec  # replace with your dataclass and computation
