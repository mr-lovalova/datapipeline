id: {{ stream_id | tojson }}  # format: domain.dataset.(variant)

from:
  stream: {{ primary_stream | tojson }}
  broadcast: {{ broadcast_stream | tojson }}

combine:
  entrypoint: {{ combine_entrypoint | tojson }}
  args: {}

# The primary stream must be partitioned. The broadcast stream must be global.
# Records combine only when their timestamps match exactly.
# Treat both combiner inputs as read-only.
# Dataset sample.keys select row identity.
# Remaining partition fields suffix series IDs.
